@inject MeteoApp.Services.login LoginService
@inject NavigationManager Nav
@implements IDisposable

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Météo Pro</a>
    </div>
</div>

<div class="flex-column">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill" aria-hidden="true"></span> Accueil
            </NavLink>
        </div>

        @if (LoginService.IsLoggedIn)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="favoris">
                    <span class="bi bi-star-fill" aria-hidden="true"></span> Mes Favoris
                </NavLink>
            </div>
        }

        <hr class="text-white opacity-25 mx-3" />

        <div class="nav-item px-3">
            @if (LoginService.IsLoggedIn)
            {
                <div class="nav-link text-blue fs-5 mb-2" style="font-weight: 600;">
                👋 Salut, @LoginService.UserName !
                </div>

                <button class="btn btn-link nav-link w-100 text-start text-danger" @onclick="HandleLogout" style="font-weight: 500;">
                <span class="bi bi-box-arrow-right" aria-hidden="true"></span> Déconnexion
                </button>
            }
            else
            {
                <NavLink class="nav-link text-primary" href="login" style="font-weight: 500;">
                <span class="bi bi-person-fill" aria-hidden="true"></span> Connexion
                </NavLink>
            }
        </div>
    </nav>
</div>

@code {
    protected override void OnInitialized()
    {
        // On demande au menu de se rafraîchir quand le service login change
        LoginService.OnChange += StateHasChanged;
    }

    private void HandleLogout()
    {
        LoginService.Logout();
        Nav.NavigateTo("/");
    }

    public void Dispose()
    {
        // Important pour éviter les erreurs de mémoire
        LoginService.OnChange -= StateHasChanged;
    }
}